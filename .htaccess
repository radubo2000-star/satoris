# Satoris API Routing for cPanel
# Routes /api/* to api.php

# Enable rewrite engine
RewriteEngine On

# If the request is for a file, serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request is for a directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route /api/* to api.php
RewriteRule ^api/(.*)$ api.php?path=$1 [L,QSA]

# Also handle /api (without trailing slash)
RewriteRule ^api$ api.php?path= [L,QSA]

# API Health Check - /api/health
RewriteRule ^api/health$ api.php?path=health [L,QSA]