# API Routing for cPanel
# Route /api/* to api.php

RewriteEngine On

# If the request is for a file, serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request is for a directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route all requests to api.php
# /health -> api.php?path=health
# /blog -> api.php?path=blog
RewriteRule ^(.*)$ api.php?path=$1 [L,QSA]

# Handle root /api request
RewriteRule ^$ api.php?path= [L,QSA]